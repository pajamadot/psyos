# Web runtime
# Local development default. In hosted environments this should point at the public API base URL.
# `PSYOS_API_URL` is the server-side fetch target for Next.js server components.
# `NEXT_PUBLIC_API_URL` is exposed to the browser for client-side auth/session calls.
PSYOS_API_URL=http://127.0.0.1:8787
NEXT_PUBLIC_API_URL=http://127.0.0.1:8787

# Human auth and email defaults
# Hosted recommendation: Google + GitHub OAuth and Resend for transactional mail.
# Local/integration recommendation: Mailpit or preview mode.
AUTH_SESSION_SECRET=replace-me
AUTH_COOKIE_DOMAIN=psyos.org
AUTH_SESSION_TTL_DAYS=30
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=
AUTH_EMAIL_PROVIDER=preview
AUTH_EMAIL_FROM=auth@psyos.org
AUTH_RESEND_API_KEY=
AUTH_E2E_TEST_EMAIL=
MAILPIT_SMTP_URL=smtp://127.0.0.1:1025
MAILPIT_HTTP_URL=http://127.0.0.1:8025

# Optional live smoke-check targets
# Override these when verifying preview or fallback deployments.
PSYOS_WEB_URL=https://psyos.org
PSYOS_API_URL=https://api.psyos.org
